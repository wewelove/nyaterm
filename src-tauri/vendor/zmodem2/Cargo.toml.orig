[package]
authors = ["Jarkko Sakkinen <jarkko.sakkinen@iki.fi>"]
description = "ZMODEM file transfer protocol"
edition = "2021"
homepage = "https://codeberg.org/jarkko/zmodem2"
license = "MIT OR Apache-2.0"
name = "zmodem2"
repository = "https://codeberg.org/jarkko/zmodem2.git"
rust-version = "1.81"
version = "0.5.0"
build = "build.rs"

[features]
default = ["std"]
std = []

[dependencies]
bitflags = "2.4"
hex = "0.4.3"
thiserror = "1.0"

[dev-dependencies]
nix = { version = "0.29", features = ["fs"] }
rstest = "0.25"
tempfile = "3.10"

[[test]]
name = "protocol"
path = "tests/protocol.rs"
harness = true

[[test]]
name = "integration"
path = "tests/integration.rs"
harness = true
